# AdCraft V2 — Variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com valores reais.

# ── Banco de dados (Supabase) ─────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
DATABASE_PASSWORD=sua-senha-do-supabase

SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_ROLE_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# Frontend (expostos ao browser via NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── LLMs ─────────────────────────────────────────────────────────────────────
# Anthropic Claude — usado por: Jarvis, 6 agentes de texto, learning-extractor, aggregator
ANTHROPIC_API_KEY=sk-ant-api03-...

# Google Gemini / Vertex AI — usado por: video_maker (Veo 3), embeddings
GEMINI_API_KEY=AIza...
GOOGLE_CLOUD_PROJECT=meu-projeto-gcp
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/caminho/para/service-account.json


# ── Storage (Cloudflare R2) ───────────────────────────────────────────────────
# Usado para armazenar vídeos gerados pelo video_maker.
# Se não configurado, vídeos são descartados após geração.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=adcraft-criativos
R2_PUBLIC_URL=https://pub-....r2.dev

# ── Plataformas de mídia (opcional — para campanhas reais) ───────────────────
META_APP_ACCESS_TOKEN=
YOUTUBE_API_KEY=

# ── Infraestrutura ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000

# ── Segurança ─────────────────────────────────────────────────────────────────
CREDENTIAL_ENCRYPTION_KEY=chave-aleatoria-de-32-bytes-hex

# ── Ambiente ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development
# Valores possíveis: development | staging | production
